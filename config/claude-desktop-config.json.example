{
  "_comment": "Agrega la sección mcpServers a tu claude_desktop_config.json existente.",
  "_comment_windows": "Ubicación: %APPDATA%\\Claude\\claude_desktop_config.json",
  "_comment_mac": "Ubicación: ~/Library/Application Support/Claude/claude_desktop_config.json",
  "_comment_linux": "Ubicación: ~/.config/Claude/claude_desktop_config.json",

  "mcpServers": {
    "google-ads": {
      "_comment": "Windows: usa la ruta al .venv/Scripts/python.exe",
      "command": "C:/Users/TU_USUARIO/adloop/.venv/Scripts/python.exe",
      "args": ["-m", "adloop"],
      "env": {
        "ADLOOP_CONFIG": "C:/Users/TU_USUARIO/.adloop/config.yaml"
      }
    }
  }
}
